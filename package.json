{
  "name": "memory-mimir",
  "version": "3.2.1",
  "description": "Long-term memory for OpenClaw powered by Mimir (graph + vector + BM25)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "memory-mimir": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "openclaw.plugin.json",
    "README.md"
  ],
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "memory",
    "mimir",
    "long-term-memory",
    "ai-memory"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "node --import tsx src/test.ts"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
